{
  "profiles": {
    "🕹 Debug Game": {
      "commandName": "Executable",
      "executablePath": "%GODOT%",
      "commandLineArgs": "--path \"./\"",
      "workingDirectory": "$(SolutionDir)"
    },
    "🧪 Debug Tests": {
      "commandName": "Executable",
      "executablePath": "%GODOT%",
      "commandLineArgs": "--path \"./\" --run-tests --listen-trace --quit-on-finish",
      "workingDirectory": "$(SolutionDir)"
    }
  }
}